# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Optional in dev (defaults to request host)
# AUTH_URL=http://localhost:3000

# Cloudflare R2 (avatar upload) — optional; preset icons work without this
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Vercel Cron — generate: openssl rand -base64 32
CRON_SECRET=

# Telegram bot (@BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=your_bot_name
# Optional webhook verification (set same value when calling setWebhook)
# TELEGRAM_WEBHOOK_SECRET=

# Public app URL for reminder links (production)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
